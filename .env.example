# Cold War — environment configuration
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.

# --- Flask ---
FLASK_SECRET_KEY=change-me-to-a-long-random-string
COLDWAR_HOST=127.0.0.1
COLDWAR_PORT=8765

# --- Storage ---
# Path to the SQLite database file (created on first run).
COLDWAR_DB=coldwar.db

# --- Worker ---
# How often the background worker runs a fetch->classify->quarantine cycle.
COLDWAR_POLL_SECONDS=120

# --- Google / Gmail OAuth (device-code flow) ---
# Create an OAuth client (type: "TVs and Limited Input devices") in Google Cloud
# Console and enable the Gmail API. Device flow uses client id + secret.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Graph / Outlook OAuth (device-code flow) ---
# Register an app in Entra ID (Azure AD). Use the "common" tenant for personal
# + work accounts, or your tenant id.
MS_CLIENT_ID=
MS_TENANT_ID=common
